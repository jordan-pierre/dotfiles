[core]
  editor = nvim
  excludesfile = ~/.config/git/ignore

[pull]
  rebase = false

[fetch]
  prune = true

[push]
  default = current

[merge]
  conflictStyle = diff3

[diff]
  # Show the whole enclosing function in diffs (git diff / show / log -p), so a
  # change inside a Metaflow @step method includes the full method rather than a
  # slice. Pairs with the *.py diff=python driver in ~/.config/git/attributes.
  functionContext = true

[log]
  decorate = short
  abbrevCommit = true
  date = relative

[user]
  signingKey = ~/.ssh/id_ed25519.pub

[gpg]
  format = ssh

[gpg "ssh"]
  allowedSignersFile = ~/.config/git/allowed_signers

[commit]
  gpgSign = true

[tag]
  gpgSign = true


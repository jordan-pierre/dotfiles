[core]
  editor = nvim
  excludesfile = ~/.config/git/ignore

[pull]
  rebase = false

[fetch]
  prune = true

[push]
  default = current

[merge]
  conflictStyle = diff3

[log]
  decorate = short
  abbrevCommit = true
  date = relative

[user]
  signingKey = ~/.ssh/id_ed25519.pub

[gpg]
  format = ssh

[gpg "ssh"]
  allowedSignersFile = ~/.config/git/allowed_signers

[commit]
  gpgSign = true

[tag]
  gpgSign = true


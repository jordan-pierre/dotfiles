// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "agent_servers": {
    "cursor": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry",
    },
  },
  "auto_update": false,
  "edit_predictions": {
    "provider": "zed",
  },
  "jupyter": {
    "enabled": true,
  },
  "vim_mode": true,
  "vim": {
    "toggle_relative_line_numbers": true,
    "use_system_clipboard": "on_yank",
  },
  "agent": {
    "default_model": {
      "provider": "ollama",
      "model": "gpt-oss:20b",
    },
    "model_parameters": [],
  },
  "ssh_connections": [
    {
      "host": "HomeServer",
      "args": [],
      "projects": [
        {
          "paths": [
            "/home/sam"
          ]
        },
        {
          "paths": [
            "/home/sam/repos/gitops-demo"
          ]
        }
      ],
      "port_forwards": [
        {
          "local_port": 8080,
          "remote_port": 8080
        },
        {
          "local_port": 3000,
          "remote_port": 3000
        }
      ]
    },
    {
      "host": "BarmiDev",
      "args": [],
      "projects": []
    }
  ],
  "icon_theme": {
    "mode": "light",
    "light": "Material Icon Theme",
    "dark": "Material Icon Theme"
  },
  "ui_font_size": 20,
  "buffer_font_size": 18,
  "buffer_font_family": "JetBrainsMono NFM",
  "theme": {
    "mode": "light",
    "light": "Cyberdream light",
    "dark": "Cyberdream dark",
  },
  "format_on_save": "on",
  "preferred_line_length": 120,
  "wrap_guides": [120],
  "show_wrap_guides": true,
  "show_whitespaces": "boundary",
  "ensure_final_newline_on_save": true,
  "remove_trailing_whitespace_on_save": true,
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "file_scan_exclusions": [
    "**/.svn",
    "**/.hg",
    "**/.jj",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    "**/__pycache__",
  ],
  "snippet_sort_order": "top",
  "buffer_font_features": {
    "calt": true,
    "liga": true,
  },
  "project_panel": {
    "git_status": true,
    "git_colors": true,
  },
  "tabs": {
    "file_icons": true,
    "git_status": true,
    "git_colors": true,
  },
  "theme_overrides": {
    "Cyberdream dark": {
      "version_control.added": "#5eff6c",
      "version_control.modified": "#ffbd5e",
      "version_control.deleted": "#ff6e5e",
    },
    "Cyberdream light": {
      "status_bar.background": "#f5f5f5",
      "version_control.added": "#008b0c",
      "version_control.modified": "#d17c00",
      "version_control.deleted": "#d11500",
    },
  },
  "git": { "inline_blame": { "enabled": false } },
  "autosave": "on_focus_change",
  "show_edit_predictions": false,
  "show_completions_on_input": true,
  // Zed defaults inlay_hints.enabled to false; VS Code/Cursor show ty hints by default.
  "inlay_hints": {
    "enabled": true,
    "show_type_hints": true,
    "show_parameter_hints": true,
    "show_other_hints": true,
  },
  "languages": {
    "Python": {
      "language_servers": ["ty", "ruff", "!basedpyright", "!pyright"],
      "format_on_save": "on",
      "formatter": [
        {
          "code_actions": {
            "source.organizeImports": true,
            "source.organizeImports.ruff": true,
            "source.fixAll": true,
            "source.fixAll.ruff": true,
          },
        },
        {
          "language_server": {
            "name": "ruff",
          },
        },
      ],
    },
    "JSON": {
      "format_on_save": "on",
      "tab_size": 4,
    },
    "JSONC": {
      "format_on_save": "on",
      "tab_size": 4,
    },
    "YAML": {
      "format_on_save": "on",
    },
    "TOML": {
      "format_on_save": "on",
    },
    "Zig": {
      // Formatting with ZLS matches `zig fmt`.
      // The Zig FAQ answers some questions about `zig fmt`:
      // https://github.com/ziglang/zig/wiki/FAQ
      "formatter": "language_server",
      "format_on_save": "on",
      // Make sure that zls is the primary language server
      "language_servers": ["zls", "..."],
      "code_actions_on_format": {
        // Run code actions that currently supports adding and removing discards.
        // "source.fixAll": true,
        // Run code actions that sorts @import declarations.
        // "source.organizeImports": true,
      },
    },
    "SQL": {
      "format_on_save": "on",
      "tab_size": 4,
      "formatter": {
        "external": {
          "command": "sql-formatter",
          "arguments": [
            "-l",
            "snowflake",
            "-c",
            "~/.config/zed/sql-formatter.json",
          ],
        },
      },
    },
  },
  "lsp": {
    "ty": {
      "settings": {
        "diagnosticMode": "workspace",
        "disableLanguageServices": false,
        "inlayHints": {
          "variableTypes": true,
          "callArgumentNames": true,
        },
        "completions": {
          "autoImport": true,
        },
      },
    },
    "ruff": {
      "initialization_options": {
        "settings": {
          "lineLength": 120,
          "showSyntaxErrors": true,
          "lint": {
            "unfixable": ["F401"],
          },
        },
      },
    },
  },
  "terminal": {
    "font_size": 18,
    "font_family": "JetBrainsMono NFM",
    "font_features": {
      "calt": true,
      "liga": true,
    },
    "shell": {
      "program": "/bin/zsh",
    },
    "cursor_shape": "bar",
    "blinking": "on",
    "option_as_meta": false,
  },
}
